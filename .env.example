# Base URL of the FastAPI pipeline's consumption API.
# Unset / empty -> same-origin, hits the demo-data route handlers in
# app/api/v1/. Set to the live pipeline host once the Hetzner VPS is up
# (e.g. https://api.askucits.com) to proxy real data instead.
# NEXT_PUBLIC_API_BASE=

# Site-wide basic-auth preview gate (middleware.ts). Set BOTH on Vercel to
# lock the site; leave either empty to disable the gate. Strip before
# public launch.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASSWORD=
